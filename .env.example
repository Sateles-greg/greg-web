# Exemplo de variáveis de ambiente

# --- Configuração do Frontend ---
VITE_API_URL=http://localhost:3001

# --- Configuração de IA ---
OPENAI_API_KEY="coloque_sua_chave_aqui"
JWT_SECRET="coloque_um_segredo_seguro_aqui"

# --- Configuração Google Cloud Platform (GCP) ---
# Caminho para o arquivo de credenciais da conta de serviço
GOOGLE_APPLICATION_CREDENTIALS="./keys/greg-service-account.json"
# ID do projeto no GCP
GOOGLE_CLOUD_PROJECT="greg-simbiotico"


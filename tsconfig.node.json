{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "vite.config.ts", 
    "src/cli/**/*.ts", 
    "src/cli/**/*.mts",
    "src/core/**/*.ts",
    "src/asi-agente/**/*.ts",
    "src/agents/**/*.ts",
    "src/autoModo.ts",
    "src/ModoAgenteMain.ts"
  ]
}
